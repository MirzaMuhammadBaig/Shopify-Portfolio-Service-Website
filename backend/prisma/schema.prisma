generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  PENDING_APPROVAL
  DELIVERED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeadlineReminder {
  TWO_DAYS
  ONE_DAY
  TWELVE_HOURS
  OVERDUE
}


// ─── USERS ──────────────────────────────────────────────

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  firstName         String   @map("first_name")
  lastName          String   @map("last_name")
  phone             String?
  avatar            String?
  role              Role     @default(USER)
  isActive          Boolean  @default(true) @map("is_active")
  emailVerified     Boolean  @default(false) @map("email_verified")
  verificationToken String?  @map("verification_token")
  provider             String?   @default("local")
  refreshToken         String?   @map("refresh_token")
  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  orders        Order[]
  customOffers  CustomOffer[]
  reviews       Review[]
  payments      Payment[]
  orderMessages OrderMessage[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─── SERVICES ───────────────────────────────────────────

model Service {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  shortDesc   String   @map("short_desc")
  price       Decimal  @db.Decimal(10, 2)
  features    Json     @default("[]")
  icon        String?
  image       String?
  isActive    Boolean  @default(true) @map("is_active")
  isFeatured  Boolean  @default(false) @map("is_featured")
  deliveryDays Int?    @map("delivery_days")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders  Order[]
  reviews Review[]

  @@index([slug])
  @@index([isActive, isFeatured])
  @@map("services")
}

// ─── ORDERS ─────────────────────────────────────────────

model Order {
  id             String      @id @default(uuid())
  orderNumber    String      @unique @map("order_number")
  userId         String      @map("user_id")
  serviceId      String?     @map("service_id")
  customOfferId  String?     @unique @map("custom_offer_id")
  status         OrderStatus @default(PENDING)
  totalAmount    Decimal     @db.Decimal(10, 2)
  requirements   String?
  deliverables   String?
  githubUrl      String?     @map("github_url")
  revisionCount  Int         @default(0) @map("revision_count")
  adminNotes     String?     @map("admin_notes")
  startedAt         DateTime?   @map("started_at")
  estimatedDelivery DateTime?   @map("estimated_delivery")
  completedAt       DateTime?   @map("completed_at")
  deliveredAt       DateTime?   @map("delivered_at")
  lastDeadlineReminder DeadlineReminder? @map("last_deadline_reminder")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  service        Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  customOffer    CustomOffer?      @relation(fields: [customOfferId], references: [id], onDelete: SetNull)
  payment        Payment?
  orderDeliverables OrderDeliverable[]
  messages       OrderMessage[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

// ─── ORDER DELIVERABLES ────────────────────────────────

model OrderDeliverable {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  fileUrl   String   @map("file_url")
  fileType  String   @map("file_type") // IMAGE or PDF
  fileName  String   @map("file_name")
  publicId  String?  @map("public_id") // Cloudinary public ID for deletion
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_deliverables")
}

// ─── ORDER MESSAGES ────────────────────────────────────

model OrderMessage {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  senderId     String   @map("sender_id")
  content      String
  isRead       Boolean  @default(false) @map("is_read")
  reminderSent Boolean  @default(false) @map("reminder_sent")
  createdAt    DateTime @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([isRead, reminderSent])
  @@map("order_messages")
}

// ─── CUSTOM OFFERS ──────────────────────────────────────

model CustomOffer {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  description String
  budget      Decimal? @db.Decimal(10, 2)
  deadline    DateTime?
  adminReply  String?  @map("admin_reply")
  quotedPrice Decimal? @map("quoted_price") @db.Decimal(10, 2)
  isAccepted  Boolean  @default(false) @map("is_accepted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order?

  @@index([userId])
  @@map("custom_offers")
}

// ─── PAYMENTS ───────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique @map("order_id")
  userId        String        @map("user_id")
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  method        String?
  transactionId String?       @map("transaction_id")
  screenshotUrl String?       @map("screenshot_url")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payments")
}


// ─── REVIEWS ────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  serviceId String   @map("service_id")
  rating    Int
  comment   String?
  isVisible Boolean  @default(true) @map("is_visible")
  editCount Int      @default(0) @map("edit_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([serviceId])
  @@index([rating])
  @@map("reviews")
}

// ─── PROJECTS ──────────────────────────────────────────

model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  category    String
  description String
  image       String?
  tags        Json     @default("[]")
  liveUrl     String?  @map("live_url")
  results     Json     @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  isFeatured  Boolean  @default(false) @map("is_featured")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([isActive, isFeatured])
  @@map("projects")
}

// ─── FAQS ──────────────────────────────────────────────

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("faqs")
}

// ─── TESTIMONIALS ──────────────────────────────────────

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String?
  rating    Int      @default(5)
  comment   String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("testimonials")
}

// ─── ABOUT PAGE ────────────────────────────────────────

model AboutStat {
  id        String   @id @default(uuid())
  label     String
  value     Int
  suffix    String   @default("+")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("about_stats")
}

model AboutStory {
  id         String   @id @default(uuid())
  title      String   @default("Our Story")
  content    String
  highlights Json     @default("[]")
  teamImage  String?  @map("team_image")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("about_story")
}

model AboutExperience {
  id          String   @id @default(uuid())
  year        String
  title       String
  description String
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("about_experiences")
}

model AboutTeamMember {
  id         String   @id @default(uuid())
  name       String
  role       String
  specialty  String
  experience String
  image      String?
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  certificates AboutCertificate[]

  @@map("about_team_members")
}

model AboutCertificate {
  id          String   @id @default(uuid())
  title       String
  issuer      String
  year        String
  description String?
  image       String?
  memberId    String   @map("member_id")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  member AboutTeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("about_certificates")
}

// ─── BLOG ───────────────────────────────────────────────

model BlogPost {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  content       String
  excerpt       String?
  coverImage    String?  @map("cover_image")
  metaTitle     String?  @map("meta_title")
  metaDesc      String?  @map("meta_desc")
  tags          Json     @default("[]")
  isPublished   Boolean  @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([isPublished])
  @@map("blog_posts")
}
